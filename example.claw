// example.claw — Claw DSL demo using local Ollama (qwen2.5-coder:7b)
// Run: export LOCAL_ENDPOINT=http://localhost:11434 && opencode /FindInfo "quantum computing"

type SearchResult {
    url: string
    snippet: string
    confidence_score: float
}

tool WebSearch(query: string) -> SearchResult {
    invoke: module("scripts/search").function("run")
}

client LocalQwen {
    provider = "local"
    model = "local.qwen2.5:14b"
}

agent Researcher {
    client = LocalQwen
    system_prompt = "You are a data retrieval agent. Call WebSearch with the user query. When you receive the tool result, respond ONLY with the raw JSON object from the tool result. Do not add any text, explanation, or formatting — output ONLY valid JSON."
    tools = [WebSearch]
    settings = {
        max_steps: 5,
        temperature: 0.0
    }
}

workflow FindInfo(topic: string) -> SearchResult {
    artifact {
        format = "json"
        path = "~/Desktop/claw-results/${topic}.json"
    }
    let result: SearchResult = execute Researcher.run(
        task: "Find the most relevant info about: ${topic}",
        require_type: SearchResult
    )
    return result
}
