// The OS will spawn this python file in a secure sandbox when the agent is executed!
tool PythonYouTubeScraperAndMailer(email_address: string) -> EmailResult {
    invoke: python("python-testing/email_youtube.py")
}

type EmailResult {
    success: boolean
    video_link: string
    summary: string
}

client LocalGameAI {
    provider = "openai"
    model = "cognitivecomputations_Dolphin3.0-R1-Mistral-24B-Q3_K_M"
    endpoint = "http://localhost/v1/chat/completions"
    api_key = "sk-deb9a31dabf973bc9aae99b28b52d66f7877a8ec02be4983"
}

// We attach the physical tool to the Agent. 
// Because this Agent only has exactly 1 tool and it contains an `invoke` path, 
// the Gateway OS executes it natively as a C-level sandbox hook instead of
// asking the LLM to hallucinate it.
agent YouTubeAssistant {
    client = LocalGameAI
    system_prompt = "You automate operations on the physical host machine."
    tools = [PythonYouTubeScraperAndMailer]
}

workflow EmailLastWatchedVideo(email_address: string) -> EmailResult {
    // The Gateway passes `email_address` safely into the python sandbox script's stdin JSON
    let result: EmailResult = execute YouTubeAssistant.run(
        email_address: email_address,
        require_type: EmailResult
    )
    return result
}
