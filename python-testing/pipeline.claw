type ResearchReport {
    company_name: string
    confidence: float
    summary: string
    tags: list<string>
}

client OpenAI {
    provider = "openai"
    model = "cognitivecomputations_Dolphin3.0-R1-Mistral-24B-Q3_K_M"
    endpoint = "http://localhost/v1"
    api_key = "Bearer sk-deb9a31dabf973bc9aae99b28b52d66f7877a8ec02be4983"
}

agent Researcher {
    client = OpenAI
    system_prompt = "You are an expert financial researcher."
}

workflow AnalyzeCompany(company: string) -> ResearchReport {
    let report: ResearchReport = execute Researcher.run(
        task: "Research ${company}",
        require_type: ResearchReport
    )
    return report
}
