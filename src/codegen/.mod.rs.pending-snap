{"run_id":"1773840529-952015000","line":22,"new":{"module_name":"clawc__codegen__tests","snapshot_name":"emits_typescript_sdk_snapshot_for_valid_document","metadata":{"source":"src/codegen/mod.rs","assertion_line":22,"expression":"output"},"snapshot":"import { z } from \"zod\";\n\nimport { OpenClawClient } from \"@openclaw/sdk\";\n\nexport interface SearchResult {\n    url: string;\n    confidence_score: number;\n    snippet: string;\n    tags: string[];\n}\n\nexport const SearchResultSchema: z.ZodType<SearchResult> = z.object({\n    url: z.string(),\n    confidence_score: z.number().min(0),\n    snippet: z.string(),\n    tags: z.array(z.string()),\n}).strict();\n\nexport interface VerifiedUser {\n    email: string;\n    age: number;\n}\n\nexport const VerifiedUserSchema: z.ZodType<VerifiedUser> = z.object({\n    email: z.string().regex(new RegExp(\"^[\\\\w-\\\\.]+@([\\\\w-]+\\\\.)+[\\\\w-]{2,4}$\")),\n    age: z.number().int().min(18),\n}).strict();\n\nexport const AnalyzeCompetitors = async (\n    company: string,\n    options: { client: OpenClawClient; resumeSessionId?: string }\n): Promise<SearchResult> => {\n    const result = await options.client.executeWorkflow({\n        workflowName: \"AnalyzeCompetitors\",\n        arguments: { company },\n        resumeSessionId: options.resumeSessionId,\n    });\n\n    return SearchResultSchema.parse(result);\n};\n\nexport const VerifyUser = async (\n    email: string,\n    options: { client: OpenClawClient; resumeSessionId?: string }\n): Promise<VerifiedUser> => {\n    const result = await options.client.executeWorkflow({\n        workflowName: \"VerifyUser\",\n        arguments: { email },\n        resumeSessionId: options.resumeSessionId,\n    });\n\n    return VerifiedUserSchema.parse(result);\n};"},"old":{"module_name":"clawc__codegen__tests","metadata":{},"snapshot":"import { z } from \"zod\";\nimport { OpenClawClient } from \"@openclaw/sdk\";\n\nexport interface SearchResult {\n    url: string;\n    confidence_sco