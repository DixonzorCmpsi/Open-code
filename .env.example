# OpenClaw OS Gateway Configuration

# LLM / SLM Endpoints (Fully Model-Agnostic)
# OpenClaw supports any provider or local model (Ollama, vLLM, HuggingFace)
# Map these exactly as you define them in your `client` blocks inside .claw files
OPENAI_API_KEY=sk-your-openai-key
CUSTOM_LLM_URL=http://localhost:11434/v1
CUSTOM_LLM_KEY=sk-optional-key

# --- Optional Production Settings ---

# Gateway Authentication (Only needed if exposing OS to the public internet)
# OPENCLAW_GATEWAY_API_KEY=prod_key_123
# Legacy alias still supported:
# GATEWAY_AUTH_KEY=prod_key_123

# Checkpointing DB (Defaults to local SQLite. Provide Redis URL for multi-container scaling)
# REDIS_URL=redis://your-managed-db:6379

# Sandbox Runtime (Defaults to local subprocesses in development)
# OPENCLAW_SANDBOX_BACKEND=docker
# OPENCLAW_PYTHON_SANDBOX_IMAGE=python:3.11-slim
# OPENCLAW_NODE_SANDBOX_IMAGE=node:22
