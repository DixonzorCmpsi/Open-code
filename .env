# Ollama / Local LLM (OpenCode)
# OpenCode reads LOCAL_ENDPOINT at startup to auto-discover local models.
# Ollama exposes an OpenAI-compatible API at port 11434.
# Models are registered as local.<model-name> (e.g. local.qwen2.5-coder:7b)
LOCAL_ENDPOINT=http://localhost:11434

# Claw DSL model ID for local Ollama (used in client blocks and opencode.json)
CLAW_LOCAL_MODEL=local.qwen2.5-coder:7b